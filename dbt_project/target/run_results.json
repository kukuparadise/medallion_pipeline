ct\n    *,\n    -- business logic: classify the day\n    case \n        when max_temp_c <= 0 then 'Freezing'\n        when max_temp_c > 0 and max_temp_c <= 15 then 'Cold'\n        when max_temp_c > 15 and max_temp_c <= 25 then 'Mild'\n        else 'Hot'\n    end as temperature_category,\n    \n    -- window function\n    lag(max_temp_c) over (order by observation_date) as prev_day_temp\nfrom staging", "relation_name": "\"weather_warehouse\".\"main\".\"int_weather_refined\"", "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-03-24T08:58:47.809714Z", "completed_at": "2026-03-24T08:58:47.813397Z"}, {"name": "execute", "started_at": "2026-03-24T08:58:47.813685Z", "completed_at": "2026-03-24T08:58:47.819342Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.011209964752197266, "adapter_response": {"_message": "OK"}, "message": null, "failures": 0, "unique_id": "test.weather_analysis.accepted_values_int_weather_refined_temperature_category__Freezing__Cold__Mild__Hot.18d1d96e8f", "compiled": true, "compiled_code": "\n    \n    \n\nwith all_values as (\n\n    select\n        temperature_category as value_field,\n        count(*) as n_records\n\n    from \"weather_warehouse\".\"main\".\"int_weather_refined\"\n    group by temperature_category\n\n)\n\nselect *\nfrom all_values\nwhere value_field not in (\n    'Freezing','Cold','Mild','Hot'\n)\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-03-24T08:58:47.822468Z", "completed_at": "2026-03-24T08:58:47.824995Z"}, {"name": "execute", "started_at": "2026-03-24T08:58:47.825261Z", "completed_at": "2026-03-24T08:58:47.840894Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.01932692527770996, "adapter_response": {"_message": "OK"}, "message": "OK", "failures": null, "unique_id": "model.weather_analysis.fct_weather_summary", "compiled": true, "compiled_code": "with refined as (\n    select * fro